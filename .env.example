VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_BASE_PATH=/ProjectTracker_React/

# Optional version overrides (CI sets these from GitHub ref + commit SHA)
# VITE_APP_VERSION=main
# VITE_APP_GIT_SHA=abc1234

# Set to "true" temporarily to log auth/session lifecycle in the browser console (production debugging).
# VITE_AUTH_DIAGNOSTICS=true

# Copy URL and anon (public) key from Supabase Dashboard → Project Settings → API.
# URL ref must match the JWT "ref" claim when using legacy anon JWT keys.

# Optional: authenticated verification (npm run verify:supabase phase 2)
# VERIFY_SUPABASE_EMAIL=
# VERIFY_SUPABASE_PASSWORD=

# Local-only migration import (NEVER commit real service role key)
# SUPABASE_SERVICE_ROLE_KEY=

# Local-only auth seed password (required by npm run seed:auth-users)
# DUMMY_USER_PASSWORD=
