VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_BASE_PATH=/ProjectTracker_React/

# Copy URL and anon (public) key from Supabase Dashboard → Project Settings → API.
# URL ref must match the JWT "ref" claim when using legacy anon JWT keys.

# Optional: authenticated verification (npm run verify:supabase phase 2)
# VERIFY_SUPABASE_EMAIL=
# VERIFY_SUPABASE_PASSWORD=
