{
  "name": "project-tracker-react",
  "private": true,
  "version": "0.93.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"scripts/**/*.ts\" --max-warnings 0",
    "verify:supabase": "tsx scripts/verify-supabase.ts",
    "smoke:supabase": "tsx scripts/smoke-test-supabase.ts",
    "seed:auth-users": "tsx scripts/seed-auth-users.ts",
    "migrate:validate": "tsx scripts/migrate-sheets-to-supabase.ts --validate",
    "migrate:dry-run": "tsx scripts/migrate-sheets-to-supabase.ts --dry-run",
    "migrate:import": "tsx scripts/migrate-sheets-to-supabase.ts",
    "test:notifications": "tsx scripts/verify-notification-retention.ts",
    "test:notification-db": "tsx --tsconfig tsconfig.app.json scripts/verify-notification-db.ts",
    "test:cnf-closure": "tsx --tsconfig tsconfig.app.json scripts/verify-cnf-closure-validation.ts",
    "test:cnf-tracker-table": "tsx --tsconfig tsconfig.app.json scripts/verify-cnf-tracker-table-columns.ts",
    "test:cnf-project-integration": "tsx --tsconfig tsconfig.app.json scripts/verify-cnf-project-integration.ts",
    "test:cnf-tracker-detail-ux": "tsx --tsconfig tsconfig.app.json scripts/verify-cnf-tracker-detail-ux.ts",
    "test:project-save": "tsx --tsconfig tsconfig.app.json scripts/verify-project-save-notifications.ts",
    "test:bmr-lock": "tsx --tsconfig tsconfig.app.json scripts/verify-bmr-lock.ts",
    "test:endorsement-support": "tsx --tsconfig tsconfig.app.json scripts/verify-endorsement-support.ts",
    "test:menu-permissions": "tsx --tsconfig tsconfig.app.json scripts/verify-menu-permissions.ts",
    "test:dashboard-drilldown": "tsx --tsconfig tsconfig.app.json scripts/verify-dashboard-drilldown.ts",
    "test:projects-db-validation": "tsx --tsconfig tsconfig.app.json scripts/verify-projects-database-validation.ts",
    "test:fixes": "npm run test:project-save && npm run test:cnf-closure && npm run test:cnf-tracker-table && npm run test:cnf-project-integration && npm run test:cnf-tracker-detail-ux && npm run test:notification-db && npm run test:notifications && npm run test:bmr-lock && npm run test:endorsement-support && npm run test:menu-permissions && npm run test:dashboard-drilldown && npm run test:projects-db-validation"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@ant-design/v5-patch-for-react-19": "^1.0.3",
    "@supabase/supabase-js": "^2.49.8",
    "@xyflow/react": "^12.11.0",
    "ag-grid-community": "^36.0.0",
    "ag-grid-react": "^36.0.0",
    "antd": "^5.25.4",
    "dayjs": "^1.11.13",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "eslint": "^9.27.0",
    "tsx": "^4.19.4",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^6.3.5"
  }
}
